# Ethereum RPC endpoints
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Base RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Deployment private key used by forge script --private-key
# Keep this in a private `.env`, never commit secrets.
CCA_DEPLOYER_PRIVATE_KEY=

# Safe / owner used for recovery and admin roles.
DEPLOYER=

# Ethereum launch script inputs
# ETH_SEPOLIA_UNISWAP_V4_POOL_MANAGER=
# ETH_MAINNET_UNISWAP_V4_POOL_MANAGER=
