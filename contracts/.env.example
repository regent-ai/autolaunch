# Base launch rehearsal and production inputs.
# Keep private values in a local `.env`; never commit secrets.

# Deployment private key used by forge script --private-key
CCA_DEPLOYER_PRIVATE_KEY=

# Common owner / safe values
STRATEGY_OPERATOR=
REGENT_MULTISIG_ADDRESS=
AUTOLAUNCH_AGENT_ID=84532:42
AUTOLAUNCH_TOKEN_NAME=Regent Agent Token
AUTOLAUNCH_TOKEN_SYMBOL=RAGENT
AUTOLAUNCH_SUBJECT_LABEL=Regent Agent Token
AUTOLAUNCH_TOTAL_SUPPLY=100000000000000000000000000000

# Shared Autolaunch infra deployment
# forge script scripts/DeployAutolaunchInfra.s.sol:DeployAutolaunchInfraScript --sig "deployFromEnv()"
AUTOLAUNCH_INFRA_OWNER=

# Addresses returned by DeployAutolaunchInfra.s.sol
REVENUE_SHARE_FACTORY_ADDRESS=
REVENUE_INGRESS_FACTORY_ADDRESS=
SUBJECT_REGISTRY_ADDRESS=
LBP_STRATEGY_FACTORY_ADDRESS=
# From AUTOLAUNCH_INFRA_RESULT_JSON.tokenFactoryAddress
TOKEN_FACTORY_ADDRESS=

# Launch deployment inputs
# forge script scripts/ExampleCCADeploymentScript.s.sol:ExampleCCADeploymentScript --sig "deployFromEnv()"
BASE_MAINNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=
UNISWAP_V4_POOL_MANAGER=
UNISWAP_V4_POSITION_MANAGER=
FACTORY_ADDRESS=0xCCccCcCAE7503Cac057829BF2811De42E16e0bD5
# Optional launch identity link.
AUTOLAUNCH_IDENTITY_REGISTRY_ADDRESS=
BASE_USDC_ADDRESS=
OFFICIAL_POOL_FEE=0
OFFICIAL_POOL_TICK_SPACING=60
AUCTION_DURATION_BLOCKS=86400
CCA_START_BLOCK_OFFSET=300
CCA_STEP_MPS=100000
CCA_STEP_BLOCK_DELTA=216
CCA_TICK_SPACING_Q96=
CCA_FLOOR_PRICE_Q96=
CCA_REQUIRED_CURRENCY_RAISED=
CCA_CLAIM_BLOCK_OFFSET=0
PROTOCOL_SKIM_BPS=100
CCA_VALIDATION_HOOK=

# Separate Base-mainnet REGENT staking rail
# forge script scripts/DeployRegentRevenueStaking.s.sol:DeployRegentRevenueStakingScript --sig "deployFromEnv()"
BASE_REGENT_TOKEN_ADDRESS=
REGENT_REVENUE_STAKING_ADDRESS=
REGENT_REVENUE_TREASURY_ADDRESS=
REGENT_REVENUE_GOVERNANCE_SAFE_ADDRESS=
REGENT_REVENUE_SUPPLY_DENOMINATOR=
